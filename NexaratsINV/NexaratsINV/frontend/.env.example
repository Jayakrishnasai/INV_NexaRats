# ═══════════════════════════════════════════════════════════
# NexaRats Pro — Frontend Environment Configuration
# Copy this file to .env and fill in values before starting.
# ═══════════════════════════════════════════════════════════

# ─── Backend connection ───────────────────────────────────
# URL of the running Express backend (without trailing slash)
VITE_API_BASE_URL=http://localhost:5000/api

# ─── Mock mode toggle ────────────────────────────────────
# true  = use localStorage mock data (no backend needed)
# false = connect to real backend via VITE_API_BASE_URL
#
# IMPORTANT: To go live, set this to false AND ensure
# the backend is running and Supabase migration has been applied.
VITE_USE_MOCKS=true

# ─── Mock only: default demo password ────────────────────
# Only used when VITE_USE_MOCKS=true and localStorage is empty.
# Has NO effect when VITE_USE_MOCKS=false (backend manages passwords).
VITE_DEFAULT_ADMIN_PASSWORD=demo1234

# ─── To switch to REAL backend: ──────────────────────────
# 1. Set VITE_USE_MOCKS=false
# 2. Set VITE_API_BASE_URL to your backend URL
# 3. Ensure backend/.env is configured (see backend/.env.example)
# 4. Run: cd backend && npm run seed   (creates Super Admin)
# 5. Run: cd backend && npm run dev    (starts on port 5000)
# 6. Run: cd frontend && npm run dev   (starts on port 5173)
