# NexaRats Backend — Environment Variables
# Copy this to .env for local development

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# CORS — must match your frontend origin exactly
CORS_ORIGIN=http://localhost:5173

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://hcqeyxbdymqnapbhvdog.supabase.co
SUPABASE_ANON_KEY=sb_publishable_GIBq8cEg6Orxh_BD3-AFuA__smAoR8Z
# Service role key — bypasses RLS. NEVER expose to frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhjcWV5eGJkeW1xbmFwYmh2ZG9nIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MjUxNjY2MSwiZXhwIjoyMDg4MDkyNjYxfQ.WJfOCTy776DPqKS2Pt-DrnNgxyp8CXEN9RWcQmG-oDs

# Direct Postgres connection (for Prisma/Migrations)
DATABASE_URL=postgresql://postgres:NexaratsINV@db.hcqeyxbdymqnapbhvdog.supabase.co:5432/postgres

# ─── JWT (Admin Auth) ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-a-256-bit-random-secret-here
JWT_REFRESH_SECRET=generate-a-different-256-bit-secret-here
# Access token lifetime (e.g., 15m, 1h)
JWT_ACCESS_EXPIRES=15m
# Refresh token lifetime (e.g., 7d)
JWT_REFRESH_EXPIRES=7d

# ─── Security ──────────────────────────────────────────────────────────────────
# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# WhatsApp endpoint protection key (optional, set in production)
WA_API_KEY=

# ─── WhatsApp (whatsapp-web.js) ────────────────────────────────────────────────
WA_SESSION_DIR=.wwebjs_auth

# ─── OTP ───────────────────────────────────────────────────────────────────────
# OTP lifespan in minutes
OTP_EXPIRES_MINUTES=5
# Max OTP attempts per phone per window
OTP_MAX_ATTEMPTS=3

# ─── Store Sessions ────────────────────────────────────────────────────────────
# Store customer session lifetime in days
STORE_SESSION_EXPIRES_DAYS=30

# ─── Razorpay (Platform Billing) ───────────────────────────────────────────────
# Your Nexarats company Razorpay keys — used for collecting SaaS subscription fees
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your-razorpay-key-secret-here

# ─── SaaS Billing & Encryption ─────────────────────────────────────────────────
# AES-256-GCM key for encrypting per-tenant Razorpay secrets at rest.
# MUST be a 64-char hex string (32 bytes). NEVER lose this key — encrypted data
# cannot be recovered without it.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RAZORPAY_ENCRYPTION_KEY=generate-64-hex-chars-here

# Razorpay webhook secret — get from Razorpay Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-here

# ─── Admin Access ──────────────────────────────────────────────────────────────
# Comma-separated IP addresses allowed to access /api/v1/admin/* routes
# Leave empty in development, MUST be set in production
# Example: "1.2.3.4,5.6.7.8"
ADMIN_IP_ALLOWLIST=

# ─── Frontend URLs ─────────────────────────────────────────────────────────────
# SaaS app frontend base URL (used for post-payment redirects)
FRONTEND_URL=http://localhost:5173
